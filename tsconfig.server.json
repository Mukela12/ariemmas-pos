{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "dist-server",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "src/server/**/*",
    "src/main/database/adapter.ts",
    "src/main/database/postgresAdapter.ts",
    "src/main/database/migrations.ts",
    "src/shared/**/*"
  ]
}
