NODE_ENV=development

# Database engine: sqlite (default) | mssql | postgres
DB_ENGINE=sqlite

# --- MSSQL (Desktop local) ---
MSSQL_SERVER=localhost
MSSQL_DATABASE=ariemmas_pos
MSSQL_USER=sa
MSSQL_PASSWORD=
MSSQL_PORT=1433
MSSQL_ENCRYPT=false
MSSQL_TRUST_CERT=true

# --- PostgreSQL (Railway cloud) ---
DATABASE_URL=
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ariemmas_pos
PG_USER=postgres
PG_PASSWORD=
PG_SSL=false

# Printer
PRINTER_INTERFACE=
PRINTER_ENABLED=false

# ZRA (Phase 2)
ZRA_API_URL=
ZRA_API_KEY=
ZRA_DEVICE_ID=
